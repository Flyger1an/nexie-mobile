{
  "expo": {
    "name": "Nexie",
    "slug": "nexie-mobile",
    "owner": "nexez-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexie",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "app.nexez.nexie",
      "supportsTablet": false,
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "Allow Nexie to turn your voice into text for agent requests.",
        "NSMicrophoneUsageDescription": "Allow Nexie to listen when you use voice input."
      }
    },
    "android": {
      "package": "app.nexez.nexie",
      "adaptiveIcon": {
        "backgroundColor": "#050507",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050507",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Nexie to listen when you use voice input.",
          "speechRecognitionPermission": "Allow Nexie to turn your voice into text for agent requests.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "expo-secure-store",
      [
        "@sentry/react-native",
        {
          "organization": "nexez-ai",
          "project": "react-native"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e8100fb-d1df-461d-9346-53b47c0a7c8e"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4e8100fb-d1df-461d-9346-53b47c0a7c8e"
    }
  }
}
