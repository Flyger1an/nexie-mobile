EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
EXPO_PUBLIC_NEXIE_API_URL=https://app.nexez.ai/api/agents/nexie

# Optional. When set, the app initializes error reporting (Sentry). Leave empty for local-only logging.
# This is the public DSN — safe to bundle.
EXPO_PUBLIC_SENTRY_DSN=

# Build-time ONLY — uploads source maps for readable stack traces. NOT an EXPO_PUBLIC_ var
# (must never ship in the bundle). Set locally in .env.local, and on EAS as a `secret`:
#   eas env:create --name SENTRY_AUTH_TOKEN --value "sntrys_..." --environment production --visibility secret
# SENTRY_AUTH_TOKEN=

# Build-time file path to the Firebase Android config (FCM). In EAS it's a 'file' secret.
# GOOGLE_SERVICES_JSON=./google-services.json
